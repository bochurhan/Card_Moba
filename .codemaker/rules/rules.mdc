```csharp
// 玩家状态（在结算代码中）
PlayerBattleState player = ctx.GetPlayer(playerId);   // ✅ 首选，O(1)
// 不要直接 ctx.Players.Find(p => p.PlayerId == id)  // ❌ 禁止

// BuffManager
BuffManager bm = ctx.GetBuffManager(playerId);

// TriggerManager
